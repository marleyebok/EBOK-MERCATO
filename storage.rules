rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Fichiers d'un utilisateur : uploads/{uid}/...
    match /uploads/{uid}/{allPaths=**} {
      // Lecture publique (photos et CV PDF affichés/téléchargeables sur les fiches).
      allow read: if true;
      // Écriture réservée au propriétaire, 8 Mo max.
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 8 * 1024 * 1024;
    }
  }
}
