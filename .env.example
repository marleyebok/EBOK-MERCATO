# Base Neon PARTAGÉE de la galaxie (la même que Médias / Workout / Dashboard).
DATABASE_URL=

# Clerk — identité unique de la galaxie EBOK.
# Clé secrète (backend). La clé "publishable" (front) est dans
# public/js/clerk.js car elle est publique.
CLERK_SECRET_KEY=

# (Optionnel) Injecté automatiquement quand on connecte un Blob store Vercel,
# nécessaire pour l'upload des photos et CV. Sans lui, l'upload est désactivé.
BLOB_READ_WRITE_TOKEN=
